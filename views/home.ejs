</section>

<section class="book" id="book">

    <h2 class="heading"> <span>Enquiry</span> Now </h2>

    <div class="row">

        <div class="image">
            <img src="/images/book-img.svg" alt="Send us an enquiry about Synergistic Biotech products">
        </div>

        <form action="/" method="post">
            <h3>Message Us</h3>
            <input type="text" name="formName" placeholder="Your name" class="box" aria-label="Your name" required>
            <input type="tel" name="number" placeholder="Your phone number" class="box" aria-label="Your phone number" required>
            <input type="email" name="email" placeholder="Your email" class="box" aria-label="Your email" required>
           
            <input type="submit" value="Send Now" class="btn">
        </form>

    </div>

</section>

